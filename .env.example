# --- MySQL local (solo servidor API — NO usar prefijo VITE_) ---
DB_HOST=localhost
# En muchas instalaciones Windows MySQL usa 3307 (revisa my.ini o el log .err)
DB_PORT=3307
DB_USER=smartdrain
DB_PASSWORD=123456
DB_NAME=smartdrain

# Contraseña de root para crear la BD (solo npm run db:setup)
MYSQL_ROOT_PASSWORD=

# Puerto del API Express
API_PORT=3001

# --- Frontend (Vite) ---
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-versatile
